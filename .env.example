# 이 파일을 복사해서 ".env" 로 저장한 뒤 값을 채우세요. (.env 는 Git에 올리지 마세요)
#
# --- AI 추천(이미지 분석): GEMINI_API_KEY 를 넣으면 Google Gemini 사용 (우선)
# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 무료 한도 보호 (기본: 호출 간 최소 13초, 하루 최대 18회 generateContent)
# GEMINI_MIN_INTERVAL_MS=13000
# GEMINI_MAX_DAILY_CALLS=18

# 선택: 모델 (gemini-1.5… 만 권장). gemini-2.x 는 코드에서 무시됩니다.
# GEMINI_MODEL=

#
# OpenAI — 체크리스트 추천·이미지(아래 키만 있고 GEMINI 없을 때)
# https://platform.openai.com/api-keys

OPENAI_API_KEY=

# 선택: 조직(Organization)이 여러 개일 때만 — platform.openai.com → Organization settings
# OPENAI_ORG_ID=org-xxxxxxxx

# 선택: 모델 (기본값은 코드와 동일 — 비워 두면 gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
